            "debug_only": true
        },
        "debug.big_walker.reference.dice_roll_state": {
            "png": "assets/design/big_walker_reference/04_dice_roll_state_reference.png",
            "debug_only": true
        },
        "debug.big_walker.reference.next_turn_overlay": {
            "png": "assets/design/big_walker_reference/05_next_turn_overlay_reference.png",
            "debug_only": true
        },
        "debug.big_walker.reference.match_alt_layout": {
            "png": "assets/design/big_walker_reference/06_match_screen_alt_layout_reference.png",
            "debug_only": true
        },
        "debug.big_walker.reference.player_select": {
            "png": "assets/design/big_walker_reference/07_player_select_screen_reference.png",
