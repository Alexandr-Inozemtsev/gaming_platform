{
  "name": "tabletopplatform-monorepo",
  "version": "0.1.0",
  "lockfileVersion": 3,
  "requires": true,
  "packages": {
    "": {
      "name": "tabletopplatform-monorepo",
      "version": "0.1.0",
      "workspaces": [
        "services/*"
      ]
    },
    "node_modules/@tabletopplatform/admin": {
      "resolved": "services/admin",
      "link": true
    },
    "node_modules/@tabletopplatform/api": {
      "resolved": "services/api",
      "link": true
    },
    "node_modules/@tabletopplatform/realtime": {
      "resolved": "services/realtime",
      "link": true
    },
    "node_modules/@tabletopplatform/rules-engine": {
      "resolved": "services/rules-engine",
      "link": true
    },
    "services/admin": {
      "name": "@tabletopplatform/admin",
      "version": "0.1.0"
    },
    "services/api": {
      "name": "@tabletopplatform/api",
      "version": "0.1.0"
    },
    "services/realtime": {
      "name": "@tabletopplatform/realtime",
      "version": "0.1.0"
    },
    "services/rules-engine": {
      "name": "@tabletopplatform/rules-engine",
      "version": "0.1.0"
    }
  }
}
