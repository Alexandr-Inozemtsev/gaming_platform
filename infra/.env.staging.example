# Staging defaults
NODE_ENV=production
LOG_LEVEL=debug
CDN_HTTP_PORT=8080
ASSET_BASE_URL=https://cdn.staging.tabletopplatform.example

# Security secrets (replace before deploy)
JWT_SECRET=replace_me_staging
ADMIN_PASSWORD=replace_me_staging

# API security switches
REQUIRE_TLS_IN_PROD=true
SESSION_TTL_MIN=30
REFRESH_TTL_DAYS=14

# Infra
POSTGRES_DB=tabletop
POSTGRES_USER=tabletop
POSTGRES_PASSWORD=replace_me_staging
POSTGRES_PORT=5432
REDIS_PORT=6379
