# Этот файл задаёт пример переменных окружения для локальной инфраструктуры MVP.
# Роль файла: служить безопасным шаблоном для разработчиков без хранения секретов в репозитории.
# Основные функции: централизовать порты, режим региона и параметры подключения к Postgres/Redis.
# Связи: используется вместе с infra/docker-compose.yml и документацией docs/infra.md.
# Важно при изменении: синхронизировать значения с compose, README и CI, не добавлять реальные секреты.
POSTGRES_DB=tabletop
POSTGRES_USER=tabletop
POSTGRES_PASSWORD=tabletop_dev
POSTGRES_PORT=5432
REDIS_PORT=6379
API_PORT=3000
REALTIME_PORT=3001
REGION_MODE=global
JWT_SECRET=generate_local_secret_only
SESSION_TTL_MIN=30
REFRESH_TTL_DAYS=30
MATCH_STATE_SNAPSHOT_EVERY_N_MOVES=1
DEFAULT_LANG=ru
RATE_LIMIT_LOGIN=10
RATE_LIMIT_MOVE=60
REQUIRE_TLS_IN_PROD=true
ASSET_BASE_URL=http://localhost:8080
