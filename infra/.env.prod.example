# Production defaults
NODE_ENV=production
LOG_LEVEL=info
CDN_HTTP_PORT=80

# Security secrets (must be strong + vaulted)
JWT_SECRET=replace_me_production
ADMIN_PASSWORD=replace_me_production

# API security switches
REQUIRE_TLS_IN_PROD=true
SESSION_TTL_MIN=30
REFRESH_TTL_DAYS=30

# Infra
POSTGRES_DB=tabletop
POSTGRES_USER=tabletop
POSTGRES_PASSWORD=replace_me_production
POSTGRES_PORT=5432
REDIS_PORT=6379
