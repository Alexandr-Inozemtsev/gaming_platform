{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://tabletopplatform.dev/contracts/runtime-sdk/v1/runtime-event-envelope.schema.json",
  "title": "Runtime Event Envelope v1",
  "type": "object",
  "required": [
    "schemaVersion",
    "eventName",
    "sessionId",
    "matchId",
    "runtime",
    "payload",
    "ts"
  ],
  "additionalProperties": false,
  "properties": {
    "schemaVersion": {
      "const": "runtime-sdk/v1"
    },
    "eventName": {
      "type": "string",
      "enum": [
        "runtime.session.started",
        "runtime.session.paused",
        "runtime.session.resumed",
        "runtime.session.ended",
        "runtime.player.input",
        "runtime.move.requested",
        "runtime.move.applied",
        "runtime.move.rejected",
        "runtime.error"
      ]
    },
    "sessionId": {
      "type": "string",
      "minLength": 3,
      "maxLength": 128
    },
    "matchId": {
      "type": "string",
      "minLength": 3,
      "maxLength": 128
    },
    "runtime": {
      "type": "object",
      "required": ["engine", "engineVersion", "platform"],
      "additionalProperties": false,
      "properties": {
        "engine": {
          "type": "string",
          "enum": ["unity", "flutter", "webgl", "unknown"]
        },
        "engineVersion": {
          "type": "string",
          "minLength": 1,
          "maxLength": 64
        },
        "platform": {
          "type": "string",
          "enum": ["ios", "android", "web", "desktop", "unknown"]
        }
      }
    },
    "userId": {
      "type": ["string", "null"],
      "maxLength": 128
    },
    "payload": {
      "type": "object"
    },
    "ts": {
      "type": "string",
      "format": "date-time"
    }
  }
}
